# CoastalTrust Bank - Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# JWT Secrets (change these to long random strings in production)
JWT_SECRET=coastaltrust_jwt_secret_key_change_this_in_production_2024
JWT_REFRESH_SECRET=coastaltrust_refresh_secret_key_change_this_in_production_2024
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Database (SQLite - file path)
DB_PATH=./coastaltrust.db

# Email Configuration (use Gmail App Password or SMTP service)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=CoastalTrust Bank <noreply@coastaltrust.com>

# Admin Email (receives support tickets)
ADMIN_EMAIL=admin@coastaltrust.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Bank Settings
BANK_NAME=CoastalTrust Bank
BANK_ROUTING_NUMBER=067000000
INTEREST_RATE_SAVINGS=0.045
INTEREST_RATE_LOAN=0.085

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
